RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxx
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
FRONTEND_URL=https://your-app.vercel.app
API_KEY=choose-a-long-random-secret
# Dedicated secret for the daily automation cron endpoint (POST /api/whatsapp/cron).
# Send it as the x-api-key header from your cron service. Keep separate from API_KEY.
CRON_SECRET=choose-another-long-random-secret
PORT=3001

# ── WhatsApp provider (payperwa | meta) ──────────────────────
WHATSAPP_PROVIDER=payperwa
PAYPERWA_BASE_URL=https://payperwa.com/api/v1
PAYPERWA_API_KEY=ppw_live_sk_xxxxxxxx
PAYPERWA_CHANNEL_ID=
PAYPERWA_WEBHOOK_SECRET=your_payperwa_webhook_secret
# Optional per-template name overrides (default = message type key):
# PPW_TPL_BILL=milk_bill
# PPW_TPL_LANG=en

# ── Meta Cloud API (future migration; leave blank for now) ───
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_APP_SECRET=
META_WABA_ID=
META_WEBHOOK_VERIFY_TOKEN=

# ── SMTP for monthly bill email report ───────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=contact@yourdomain.com
